<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Space TV - Login</title>
    <style>
        body { font-family: sans-serif; background: #0066cc; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .login-card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); width: 90%; max-width: 350px; text-align: center; }
        h2 { color: #333; margin-bottom: 20px; }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 1rem; }
        button { width: 100%; padding: 12px; background: #0066cc; color: white; border: none; border-radius: 6px; font-size: 1rem; font-weight: bold; cursor: pointer; margin-top: 10px; }
        #msg { color: red; margin-top: 10px; font-size: 0.9rem; min-height: 20px; }
    </style>
</head>
<body>

    <div class="login-card">
        <h2>Space TV Login</h2>
        <input type="text" id="user" placeholder="Username" autocomplete="off">
        <input type="password" id="pass" placeholder="Password">
        <button onclick="doLogin()">Login</button>
        <div id="msg"></div>
    </div>

    <script>
        // If they are already logged in, skip to dashboard
        if (localStorage.getItem("isLoggedIn") === "true") {
            window.location.href = "/dashboard";
        }

        async function doLogin() {
            const u = document.getElementById('user').value;
            const p = document.getElementById('pass').value;
            const msg = document.getElementById('msg');
            
            if(!u || !p) { msg.innerText = "Enter details"; return; }
            
            msg.innerText = "Checking...";
            
            try {
                const res = await fetch(`/login?user=${encodeURIComponent(u)}&pass=${encodeURIComponent(p)}`);
                const status = await res.text();
                
                if (status === "success") {
                    // GIVE THE KEY
                    localStorage.setItem("isLoggedIn", "true");
                    window.location.href = "/dashboard";
                } else {
                    msg.innerText = "Invalid Username or Password";
                }
            } catch (err) {
                msg.innerText = "Connection Error";
            }
        }
    </script>
</body>
</html>
