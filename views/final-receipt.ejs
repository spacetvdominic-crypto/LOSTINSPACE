<!DOCTYPE html>
<html>
<head>
    <style>
        body { background:#555; display:flex; justify-content:center; padding:20px; font-family:monospace; }
        .r { background:white; width:300px; padding:20px; text-align:center; }
        .row { display:flex; justify-content:space-between; margin:10px 0; border-bottom:1px dashed #eee; }
    </style>
</head>
<body>
    <div class="r">
        <img src="/logo.png" style="width:100px;">
        <h3>SPACE TV RECEIPT</h3>
        <div class="row"><span>Date:</span><span id="d"></span></div>
        <div class="row"><span>Customer:</span><span id="n"></span></div>
        <div class="row"><span>Staff:</span><span id="s"></span></div>
        <div style="text-align:left; margin:15px 0;"><strong>Work:</strong><br><span id="rem"></span></div>
        <h2 style="border-top:2px solid #000; padding-top:10px;">GHS <span id="amt"></span></h2>
        <p><i>"Where Excellent Performance Matters"</i></p>
        <button onclick="window.print()" style="width:100%; padding:10px; margin-top:10px;">Print/PDF</button>
    </div>
    <script>
        const data = JSON.parse(localStorage.getItem('tempReceipt'));
        if(data){
            d.innerText = new Date().toLocaleDateString();
            n.innerText = data.name;
            s.innerText = data.installer;
            rem.innerText = data.remarks;
            amt.innerText = data.amount;
        }
    </script>
</body>
</html>
