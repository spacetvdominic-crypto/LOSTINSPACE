<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: sans-serif; padding: 20px; background: #f9f9f9; }
        .box { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        label { font-weight: bold; display: block; margin-top: 15px; color: #333; }
        input, select, textarea { width: 100%; padding: 12px; margin-top: 5px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        .sub { background: #0066cc; color: white; border: none; padding: 15px; width: 100%; margin-top: 25px; font-weight: bold; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="box">
        <h2 id="cN" style="color:#0066cc; margin-top:0;"></h2>
        <p id="cT" style="font-weight:bold;"></p>
        <form id="f">
            <label>Current Status</label>
            <select id="s">
                <option value="In Progress">In Progress</option>
                <option value="Done">Done</option>
                <option value="Cancel">Cancel Job</option>
            </select>

            <label>Remarks (Select One)</label>
            <select id="r">
                <option value="Completed Successfully">Completed Successfully</option>
                <option value="Cancelled">Cancelled</option>
                <option value="Return Job">Return Job</option>
                <option value="Rescheduled">Rescheduled</option>
                <option value="Already working">Already working</option>
                <option value="Customer did not pick">Customer did not pick</option>
                <option value="Faulty decoder">Faulty decoder</option>
            </select>

            <label>Additional Notes</label>
            <textarea id="n" rows="3" placeholder="Enter any extra details here..."></textarea>

            <label>Amount Charged (GHS)</label>
            <input type="number" id="a" value="0">

            <button type="submit" class="sub">SUBMIT UPDATE</button>
        </form>
    </div>
    <script>
        const params = new URLSearchParams(window.location.search);
        document.getElementById('cN').innerText = params.get('name');
        document.getElementById('cT').innerText = "Tel: " + params.get('tel');

        document.getElementById('f').onsubmit = async (e) => {
            e.preventDefault();
            const data = {
                rowId: params.get('rowId'),
                name: params.get('name'),
                status: s.value,
                amount: a.value,
                remarks: r.value,
                notes: n.value,
                installer: localStorage.getItem('installerName')
            };
            localStorage.setItem('tempReceipt', JSON.stringify(data));
            await fetch('/submit-update', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            window.location.href = s.value === "Done" ? '/receipt-flip' : '/dashboard';
        };
    </script>
</body>
</html>
