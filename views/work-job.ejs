<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: sans-serif; padding: 20px; }
        label { font-weight: bold; display: block; margin-top: 15px; }
        input, select, textarea { width: 100%; padding: 10px; margin-top: 5px; box-sizing: border-box; }
        .sub { background: #0066cc; color: white; border: none; padding: 15px; width: 100%; margin-top: 20px; font-weight: bold; }
    </style>
</head>
<body>
    <h2 id="cN"></h2>
    <form id="f">
        <label>Status</label>
        <select id="s">
            <option value="In Progress">In Progress</option>
            <option value="Done">Done</option>
            <option value="Return Job">Return Job (No Pay)</option>
        </select>
        <label>Amount (GHS)</label>
        <input type="number" id="a" value="0">
        <label>Remarks</label>
        <textarea id="r"></textarea>
        <button type="submit" class="sub">SUBMIT</button>
    </form>
    <script>
        const params = new URLSearchParams(window.location.search);
        document.getElementById('cN').innerText = params.get('name');

        document.getElementById('f').onsubmit = async (e) => {
            e.preventDefault();
            const data = {
                rowId: params.get('rowId'),
                name: params.get('name'),
                status: s.value,
                amount: a.value,
                remarks: r.value,
                installer: localStorage.getItem('installerName'),
                notes: ""
            };
            localStorage.setItem('tempReceipt', JSON.stringify(data));
            await fetch('/submit-update', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            window.location.href = s.value === "Done" ? '/receipt-flip' : '/dashboard';
        };
    </script>
</body>
</html>
