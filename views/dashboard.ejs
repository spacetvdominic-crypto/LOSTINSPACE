<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: sans-serif; background: #eee; margin: 0; }
        .h { background: #0066cc; color: white; padding: 15px; text-align: center; }
        .card { background: white; margin: 10px; padding: 15px; border-radius: 5px; border-left: 5px solid #0066cc; }
        .btn { display: block; background: #0066cc; color: white; text-align: center; padding: 12px; text-decoration: none; margin-top: 10px; border-radius: 5px; font-weight: bold; border:none; width:100%; cursor:pointer;}
        a.tel-link { color: #0066cc; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <div class="h"><h2>Space TV Pending</h2></div>
    <div id="list"></div>
    <script>
        async function startJob(id, name, tel, loc, prob) {
            await fetch(`/start-job?rowId=${id}`);
            window.location.href = `/work-job?rowId=${id}&name=${name}&tel=${tel}&loc=${loc}&prob=${prob}`;
        }
        async function load() {
            const res = await fetch('/api/jobs');
            const jobs = await res.json();
            const list = document.getElementById('list');
            list.innerHTML = jobs.length ? '' : '<p style="text-align:center">No Pending Jobs</p>';
        jobs.forEach(j => {
                // We use j.loc and j.prob because that's what we named them in the Apps Script above
                list.innerHTML += `<div class="card">
                    <h3>${j.customer || 'No Name'}</h3>
                    <p><strong>Tel:</strong> <a href="tel:${j.tel}" class="tel-link">${j.tel || 'No Number'}</a></p>
                    <p><strong>Loc:</strong> ${j.loc || 'No Location'}</p>
                    <p><strong>Type:</strong> ${j.type || 'N/A'}</p>
                    <p><strong>Problem:</strong> <i>${j.prob || 'No Problem Stated'}</i></p>
                    <button onclick="startJob('${j.rowId}', '${encodeURIComponent(j.customer)}', '${encodeURIComponent(j.tel)}', '${encodeURIComponent(j.loc)}', '${encodeURIComponent(j.prob)}')" class="btn">START JOB</button>
                </div>`;
            });
        }
        load();
    </script>
</body>
</html>
